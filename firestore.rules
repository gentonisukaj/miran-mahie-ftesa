rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if the user is the admin (based on email)
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "ukajgentonis88@gmail.com" && 
        request.auth.token.email_verified == true
      );
    }

    // Domain validator for RSVP
    function isValidRSVP(data) {
      return data.keys().hasAll(['firstName', 'lastName', 'guestsCount', 'createdAt']) &&
             data.firstName is string && data.firstName.size() > 0 && data.firstName.size() < 100 &&
             data.lastName is string && data.lastName.size() > 0 && data.lastName.size() < 100 &&
             data.guestsCount is int && data.guestsCount > 0 && data.guestsCount <= 20 &&
             data.createdAt is string; // ISO 8601
    }

    match /rsvps/{rsvpId} {
      // Anyone can create an RSVP (public form)
      allow create: if isValidRSVP(request.resource.data);
      
      // Only admin can read the list
      allow read: if isAdmin();
      
      // No updates or deletes allowed for now
      allow update, delete: if isAdmin();
    }
  }
}
